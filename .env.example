# Gmail OAuth — see README step 3
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=you@example.com

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Where to send the recap (usually same as GMAIL_USER)
RECAP_RECIPIENT=you@example.com

# Labels (created automatically if missing)
LABEL_RAW=TLDR/raw
LABEL_PROCESSED=TLDR/processed

# Strict-mode threshold: if fewer items than this are extracted across
# all emails, treat as a parser failure
MIN_ITEMS_BEFORE_FAILURE=5

TZ=Europe/Madrid
